{
  "name": "my-portfolio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "verify": "npm run lint && npm run typecheck && npm run build",
    "prepare": "husky"
  },
  "dependencies": {
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.38.0",
    "@tailwindcss/vite": "^4.1.14",
    "@types/node": "^24.6.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.0.4",
    "eslint": "^9.38.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.0",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.5",
    "prettier": "^3.6.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "typescript-eslint": "^8.46.1",
    "vite": "^7.1.10"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,html,json,md}": [
      "prettier --write"
    ]
  },
  "description": "프런트엔드 제품 엔지니어 전희수의 개인 포트폴리오입니다. SSAFY에서의 학습과 동아리/사이드 프로젝트 경험을 바탕으로, 실제로 맡아 온 역할과 성장 관점을 한 페이지에 정리했습니다. 밝은 톤과 정돈된 정보 구조로 Notion 프로필과 이어지는 컨텍스트를 제공합니다.",
  "main": "index.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HeesooJun/portfolio_page.git"
  },
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/HeesooJun/portfolio_page/issues"
  },
  "homepage": "https://github.com/HeesooJun/portfolio_page#readme"
}
