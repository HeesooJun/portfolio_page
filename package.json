{
  "name": "my-portfolio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "verify": "npm run lint && npm run typecheck && npm run build",
    "asset:prepare-runtime": "node scripts/experience/prepare-runtime-assets.mjs",
    "asset:gltf": "gltf-transform",
    "asset:gltfjsx": "gltfjsx",
    "prepare": "husky"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@react-three/offscreen": "^0.0.8",
    "@react-three/postprocessing": "^3.0.4",
    "@theatre/core": "^0.7.2",
    "@theatre/studio": "^0.7.2",
    "detect-gpu": "^5.0.70",
    "gsap": "^3.15.0",
    "lenis": "^1.3.23",
    "leva": "^0.10.1",
    "postprocessing": "^6.39.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "three": "^0.184.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@gltf-transform/cli": "^4.3.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "draco3d": "^1.5.7",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "gltfjsx": "^6.5.3",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "meshoptimizer": "^1.1.1",
    "playwright": "^1.60.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vite": "^8.0.14",
    "vite-plugin-glsl": "^1.6.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{mjs,cjs}": [
      "prettier --write"
    ],
    "*.{css,html,json,md}": [
      "prettier --write"
    ]
  },
  "overrides": {
    "ws": "^8.20.1"
  },
  "description": "프런트엔드 제품 엔지니어 전희수의 개인 포트폴리오입니다. SSAFY에서의 학습과 동아리/사이드 프로젝트 경험을 바탕으로, 실제로 맡아 온 역할과 성장 관점을 한 페이지에 정리했습니다. 밝은 톤과 정돈된 정보 구조로 Notion 프로필과 이어지는 컨텍스트를 제공합니다.",
  "main": "index.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HeesooJun/portfolio_page.git"
  },
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/HeesooJun/portfolio_page/issues"
  },
  "homepage": "https://github.com/HeesooJun/portfolio_page#readme"
}
